{
  "name": "aldo-toolkit",
  "version": "0.2.0",
  "private": true,
  "description": "ALDO Toolkit (Azure Local DisconnectedOps Toolkit)",
  "license": "Apache-2.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -ws --if-present",
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\" \"npm run dev -w apps/worker\"",
    "lint": "npm run lint -ws --if-present",
    "test": "npm run test -ws --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:openapi": "npm run openapi:generate -w apps/api && npm run openapi:types -w apps/web"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.8",
    "concurrently": "^9.1.2",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.0.8"
  }
}
