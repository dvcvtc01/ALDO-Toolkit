    "/api/v1/runs/{runId}/evidence": {
      "post": {
        "tags": [
          "runs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "requested",
                      "in_progress",
                      "completed",
                      "failed"
                    ]
                  },
                  "startedAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "finishedAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "executedBy": {
                    "type": "object",
                    "properties": {
                      "hostname": {
                        "type": "string",
                        "minLength": 1
                      },
                      "username": {
                        "type": "string",
                        "minLength": 1
                      },
                      "runnerVersion": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "hostname",
                      "username",
                      "runnerVersion"
                    ],
                    "additionalProperties": false
                  },
                  "transcriptText": {
                    "type": "string"
                  },
                  "transcriptLines": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": {}
                    },
                    "default": []
                  },
                  "resultJson": {},
                  "artifacts": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "filename": {
                          "type": "string",
                          "minLength": 1
                        },
                        "relativePath": {
                          "type": "string",
                          "minLength": 1
                        },
                        "sha256": {
                          "type": "string",
                          "pattern": "^[A-Fa-f0-9]{64}$"
                        },
                        "sizeBytes": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "modifiedAt": {
                          "type": "string",
                          "format": "date-time"
                        }
                      },
                      "required": [
                        "filename",
                        "sha256",
                        "sizeBytes"
                      ],
                      "additionalProperties": false
                    },
                    "default": []
                  }
                },
                "required": [
                  "status",
                  "executedBy"
                ],
                "additionalProperties": false
              }
            }
          }
        },
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "in": "path",
            "name": "runId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
