        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 128
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 1000
                  },
                  "environmentType": {
                    "type": "string",
                    "enum": [
                      "air-gapped",
                      "limited-connectivity"
                    ]
                  },
                  "deploymentModel": {
                    "type": "string",
                    "enum": [
                      "physical"
                    ],
                    "default": "physical"
                  },
                  "domainName": {
                    "type": "string"
                  },
                  "dnsServers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "minItems": 1,
                    "maxItems": 6
                  },
                  "nodeCountTarget": {
                    "type": "integer",
                    "minimum": 3,
                    "maximum": 16
                  },
                  "managementIpPool": {
                    "type": "string",
                    "minLength": 7,
                    "maxLength": 64
                  },
                  "ingressIp": {
                    "type": "string"
                  },
                  "deploymentRange": {
                    "type": "string"
                  },
                  "containerNetworkRange": {
                    "type": "string"
                  },
                  "identityProviderHost": {
                    "type": "string"
                  },
                  "ingressEndpoints": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string",
                          "minLength": 2,
                          "maxLength": 64
                        },
                        "fqdn": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "name",
                        "fqdn"
                      ],
                      "additionalProperties": false
                    },
                    "minItems": 1,
                    "maxItems": 16
                  },
                  "notes": {
                    "type": "string",
                    "maxLength": 4000
                  }
                },
                "required": [
                  "name",
                  "environmentType",
                  "domainName",
                  "dnsServers",
                  "nodeCountTarget",
                  "managementIpPool",
                  "ingressIp",
                  "deploymentRange",
                  "containerNetworkRange",
                  "identityProviderHost",
                  "ingressEndpoints"
                ],
                "additionalProperties": false
              }
